    "moduleResolution": "Bundler",
    "outDir": "dist",
    "declaration": false,
    "noEmit": false,
    "rootDir": "src"
  },
  "include": ["src"],
  "exclude": ["src/ui", "tests", "**/*.test.ts", "**/*.test.tsx"]
}
