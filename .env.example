# Howa environment — optional overrides.
# All keys have sensible defaults; none are required to run.
#
# HOWA_* names are canonical. COLOSSEUM_* names are honored for backward
# compatibility with v0.1 deployments installed before the Howa rename;
# you can safely keep them in an existing .env without changes.

# ─── Server ──────────────────────────────────────────────────────────────
# Default binds to 127.0.0.1:18799.
HOWA_PORT=18799
HOWA_HOST=127.0.0.1

# ─── State directory ─────────────────────────────────────────────────────
# Override where trials, receipts, and fixtures are stored.
# Default: ./colosseum-state (preserved for v0.1 trial continuity)
HOWA_STATE_ROOT=

# ─── Lab-only adapters ───────────────────────────────────────────────────
# Comma-separated list of lab adapters to expose in UI/CLI.
# These are NOT shown by default.
HOWA_LAB_ADAPTERS=

# ─── Context-stamina mode ────────────────────────────────────────────────
# Enable multi-turn persistent session for the Hermes adapter so
# context-stamina pack tests can build on prior conversation state.
HOWA_CONTEXT_STAMINA=

# ─── External agent binaries ─────────────────────────────────────────────
# Override paths to agent binaries. Defaults to the binary name on PATH.
AEDIS_BIN=aedis
OPENCLAW_BIN=openclaw
BETTERCLAW_BIN=betterclaw
PTAH_BIN=ptah

# ─── Squidley adapters ──────────────────────────────────────────────────
SQUIDLEY_URL=http://127.0.0.1:18790
SQUIDLEY_V2_URL=http://127.0.0.1:18791
LUNA_URL=http://127.0.0.1:18792

# ─── Legacy COLOSSEUM_* names (still honored) ───────────────────────────
# COLOSSEUM_PORT=18799
# COLOSSEUM_HOST=127.0.0.1
# COLOSSEUM_STATE=
# COLOSSEUM_STATE_ROOT=
# COLOSSEUM_LAB_ADAPTERS=
# COLOSSEUM_CONTEXT_STAMINA=
