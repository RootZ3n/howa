[Unit]
Description=Howa — Agent Proving Ground (HTTP API + bundled UI)
Documentation=https://github.com/RootZ3n/howa
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
# Example values for a public install. Replace these before installing:
#   User/Group: a local service account that owns HOWA_STATE_ROOT
#   WorkingDirectory: the checked-out Howa repo or installed package dir
#   HOWA_STATE_ROOT/ReadWritePaths: a dedicated state directory
User=howa
Group=howa
WorkingDirectory=/opt/howa
ExecStartPre=/bin/bash -lc 'test -f dist/api/server.js || /usr/bin/npm run build'
ExecStart=/usr/bin/npm run start
Restart=on-failure
RestartSec=3

# Bind locally by default. Set HOWA_HOST=0.0.0.0 to expose on the LAN
# (and front it with a real reverse proxy if you do).
Environment=HOWA_PORT=18799
Environment=HOWA_HOST=127.0.0.1
Environment=HOWA_STATE_ROOT=/var/lib/howa
Environment=NODE_ENV=production

# Conservative hardening — Howa only needs read on its repo and
# read/write on its state directory. Adjust if you point STATE_ROOT
# elsewhere.
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ProtectHome=read-only
ReadWritePaths=/var/lib/howa

# Logs go to journald — `journalctl -u howa -f` to tail.
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
