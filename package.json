{
  "name": "colosseum",
  "version": "0.1.0",
  "description": "Colosseum — Agent Proving Ground. Stop guessing if your agent works. Put it in the arena.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RootZ3n/colosseum.git"
  },
  "bugs": {
    "url": "https://github.com/RootZ3n/colosseum/issues"
  },
  "homepage": "https://github.com/RootZ3n/colosseum#readme",
  "files": [
    "dist",
    "docs",
    "scripts",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "SECURITY.md"
  ],
  "bin": {
    "colosseum": "./dist/cli/index.js"
  },
  "scripts": {
    "dev": "concurrently -k -n api,ui -c yellow,cyan \"npm:dev:api\" \"npm:dev:ui\"",
    "dev:api": "tsx watch src/api/server.ts",
    "dev:ui": "vite",
    "build": "tsc -p tsconfig.build.json && vite build",
    "build:cli": "tsc -p tsconfig.build.json",
    "start": "node dist/api/server.js",
    "start:api": "node dist/api/server.js",
    "start:ui": "vite preview",
    "cli": "tsx src/cli/index.ts",
    "smoke": "node scripts/smoke.mjs pass",
    "smoke:fail": "node scripts/smoke.mjs fail",
    "verify:release": "node scripts/verify-release.mjs",
    "audit:release": "npm audit --audit-level=moderate --omit=optional",
    "package:windows": "powershell -ExecutionPolicy Bypass -File scripts/package-windows-zip.ps1",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:all": "vitest run --config vitest.all.config.ts",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "express": "^4.19.2",
    "nanoid": "^5.0.7",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.10",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3",
    "vite": "^6.4.2",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=18.17"
  }
}
